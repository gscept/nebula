{
    "Nebula": {
        "version": 3,
        "Dependencies": [
            "Shadows"
        ],
        "ImportBuffers": [
            "ClusterBuffer",
            "LightList",
            "ClusterLightIndexLists",
            "ClusterDecalList",
            "ClusterDecalIndexLists",
            "ClusterFogList",
            "ClusterFogIndexLists",
            "ClusterGIList",
            "ClusterGIIndexLists",
            "GridBuffer",
            "GridLightIndexLists",
            "GridDecalList",
            "GridDecalIndexLists",
            "GridFogList",
            "GridFogIndexLists",
            "RayTracingObjectBindings",
            "HistogramCounters",
            "VegetationDrawCountBuffer",
            "VegetationGrassDrawsBuffer",
            "VegetationGrassArgumentsBuffer",
            "VegetationMeshDrawsBuffer",
            "VegetationMeshArgumentsBuffer"
        ],
        "ImportTextures": [
            "HBAOInternal0",
            "HBAOInternal1",
            "BloomIntermediate",
            "SunShadowDepth"
        ],
        "LocalTextures": [
            {
                "name": "ColorBuffer",
                "format": "SRGBA8",
                "usage": "Render|TransferSource",
                "relativeSize": [
                    1.0,
                    1.0
                ]
            },
            {
                "name": "SceneBuffer",
                "format": "SRGBA8",
                "usage": "Render|TransferSource",
                "relativeSize": [
                    1.0,
                    1.0
                ]
            },
            {
                "name": "SSAOBuffer",
                "format": "R16F",
                "usage": "ReadWrite",
                "relativeSize": [
                    1.0,
                    1.0
                ]
            },
            {
                "name": "BloomBuffer",
                "format": "R16G16B16A16F",
                "usage": "Render|TransferSource|ReadWrite",
                "relativeSize": [
                    1.0,
                    1.0
                ]
            },
            {
                "name": "LightBuffer",
                "format": "R11G11B10F",
                "usage": "Render|ReadWrite|TransferSource",
                "relativeSize": [
                    1.0,
                    1.0
                ],
                "mips": "auto"
            },
            {
                "name": "LightBufferMS",
                "format": "R11G11B10F",
                "usage": "Render|ReadWrite|TransferSource",
                "relativeSize": [
                    1.0,
                    1.0
                ],
                "samples": 4
            },
            {
                "name": "AlphaLightBuffer",
                "format": "R16G16B16A16F",
                "usage": "Render|ReadWrite|TransferSource",
                "relativeSize": [
                    1.0,
                    1.0
                ]
            },
            {
                "name": "AlphaLightBufferMS",
                "format": "R16G16B16A16F",
                "usage": "Render|ReadWrite|TransferSource",
                "relativeSize": [
                    1.0,
                    1.0
                ],
                "samples": 4
            },
            {
                "name": "LightDebugBuffer",
                "format": "R16G16B16A16F",
                "usage": "ReadWrite",
                "relativeSize": [
                    1.0,
                    1.0
                ]
            },
            {
                "name": "VolumetricFogBuffer0",
                "format": "R16G16B16A16F",
                "usage": "ReadWrite",
                "relativeSize": [
                    0.25,
                    0.25
                ]
            },
            {
                "name": "VolumetricFogBuffer1",
                "format": "R16G16B16A16F",
                "usage": "ReadWrite",
                "relativeSize": [
                    0.25,
                    0.25
                ]
            },
            {
                "name": "ZBufferMS",
                "format": "D32S8",
                "usage": "Render|Sample",
                "relativeSize": [
                    1.0,
                    1.0
                ],
                "samples": 4
            },
            {
                "name": "ZBuffer",
                "format": "D32S8",
                "usage": "Render|Sample",
                "relativeSize": [
                    1.0,
                    1.0
                ]
            },
            {
                "name": "Depth",
                "format": "R32F",
                "mips": "auto",
                "usage": "Sample|ReadWrite",
                "relativeSize": [
                    1.0,
                    1.0
                ]
            },
            {
                "name": "Stencil",
                "format": "R8",
                "usage": "TransferDestination|Sample",
                "relativeSize": [
                    1.0,
                    1.0
                ]
            },
            {
                "name": "ReflectionBuffer",
                "format": "R16G16B16A16F",
                "usage": "ReadWrite",
                "relativeSize": [
                    1.0,
                    1.0
                ]
            },
            {
                "name": "TerrainPosBuffer",
                "format": "R16G16F",
                "usage": "Render",
                "relativeSize": [
                    1.0,
                    1.0
                ]
            },
            {
                "name": "TerrainPosBufferMS",
                "format": "R16G16F",
                "usage": "Render",
                "relativeSize": [
                    1.0,
                    1.0
                ],
                "samples": 4
            },
            {
                "name": "RayTracingTestOutput",
                "format": "R16G16B16A16F",
                "fixedSize": [
                    640,
                    480
                ],
                "usage": "ReadWrite"
            }
        ],
        "ExportTextures": [
            "ColorBuffer",
            "SceneBuffer"
        ],

        "Submissions": [
            {
                "name": "Compute Prepass",
                "queue": "Compute",
                "_comment": "Perform clustering AABB generation and run culling for clustering systems",
                "ops": [
                    {
                        "subgraph": {
                            "name": "Raytracing Structures Update"
                        }
                    },
                    {
                        "subgraph": {
                            "name": "Cluster AABB Generation"
                        }
                    },
                    {
                        "subgraph": {
                            "name": "Lights Copy"
                        }
                    },
                    {
                        "subgraph": {
                            "name": "Lights Cull"
                        }
                    },
                    {
                        "subgraph": {
                            "name": "Decal Copy"
                        }
                    },
                    {
                        "subgraph": {
                            "name": "Decal Cull"
                        }
                    },
                    {
                        "subgraph": {
                            "name": "Fog Copy"
                        }
                    },
                    {
                        "subgraph": {
                            "name": "Fog Cull"
                        }
                    },
                    {
                        "subgraph": {
                            "name": "GI Copy"
                        }
                    },
                    {
                        "subgraph": {
                            "name": "GI Cull"
                        }
                    },
                    {
                        "subgraph": {
                            "name": "Sun Terrain Shadows"
                        }
                    },
                    {
                        "subgraph": {
                            "name": "Raytracing Light Grid Gen"
                        }
                    },
                    {
                        "subgraph": {
                            "name": "Raytracing Light Grid Cull"
                        }
                    },
                    {
                        "subgraph": {
                            "name": "Terrain Raytracing Mesh Generate"
                        }
                    },
                    {
                        "subgraph": {
                            "name": "DDGI Probe Update"
                        }
                    },
                    {
                        "subgraph": {
                            "name": "DDGI Probe Finalize"
                        }
                    }
                ]
            },

            {
                "name": "Prepass",
                "queue": "Graphics",
                "_comment": "Calculate shadow maps and depth prepass",
                "ops": [

                    {
                        "subgraph": {
                            "name": "StaticUI"
                        }
                    },

                    {
                        "subgraph": {
                            "name": "Vegetation Clear Draws"
                        }
                    },
                    {
                        "subgraph": {
                            "name": "Vegetation Generate Draws"
                        }
                    },
                    {
                        "subgraph": {
                            "name": "Vegetation Draw CPU Readback"
                        }
                    },

                    {
                        "subgraph": {
                            "name": "Terrain Prepare"
                        }
                    },
                    {
                        "subgraph": {
                            "name": "Terrain Indirection Copy"
                        }
                    },

                    {
                        "render": {
                            "name": "Terrain Prepass",
                            "targets": [
                                {
                                    "name": "TerrainPosBufferMS",
                                    "clear": [
                                        0,
                                        0,
                                        0,
                                        255
                                    ],
                                    "flags": "Store",
                                    "resolve": "TerrainPosBuffer"
                                }
                            ],
                            "depth": {
                                "name": "ZBufferMS",
                                "clear_depth": 1,
                                "clear_stencil": 0,
                                "flags": "Store|StoreStencil"
                            },
                            "ops": [
                                {
                                    "subgraph": {
                                        "name": "Terrain Prepass"
                                    }
                                }
                            ]
                        }
                    },

                    {
                        "render": {
                            "name": "Opaque Prepass",
                            "depth": {
                                "name": "ZBufferMS",
                                "flags": "Store|StoreStencil|Load|LoadStencil"
                            },
                            "ops": [
                                {
                                    "batch": {
                                        "name": "FlatGeometryDepth"
                                    }
                                },
                                {
                                    "subgraph": {
                                        "name": "Vegetation Prepass"
                                    }
                                }
                            ]
                        }
                    },
                    {
                        "subgraph": {
                            "name": "Terrain Page Extract"

                        }
                    },
                    {
                        "subgraph": {
                            "name": "Terrain Update Caches"

                        }
                    },
                    {
                        "subgraph": {
                            "name": "Terrain Pages Clear"

                        }
                    },
                    {
                        "subgraph": {
                            "name": "Depth Extract"
                        }
                    },

                    {
                        "subgraph": {
                            "name": "Depth Downsample"
                        }
                    }
                ]
            },

            {
                "name": "Scene",
                "wait_for_submissions": [
                    "Compute Prepass",
                    "Prepass",
                    "Shadows"
                ],
                "queue": "Graphics",
                "last_submit": true,
                "_comment": "Main graphics submission",
                "ops": [
                    {
                        "render": {
                            "name": "Opaque Pass",
                            "resource_dependencies": [
                                {
                                    "name": "SunShadowDepth",
                                    "stage": "PixelShaderRead"
                                },
                                {
                                    "name": "ClusterLightIndexLists",
                                    "stage": "PixelShaderRead"
                                },
                                {
                                    "name": "ClusterFogIndexLists",
                                    "stage": "PixelShaderRead"
                                },
                                {
                                    "name": "ClusterDecalIndexLists",
                                    "stage": "PixelShaderRead"
                                }
                            ],
                            "targets": [
                                {
                                    "name": "LightBufferMS",
                                    "clear": [
                                        0,
                                        0,
                                        0,
                                        0
                                    ],
                                    "flags": "Store"
                                }
                            ],
                            "depth": {
                                "name": "ZBufferMS",
                                "flags": "Load|Store"
                            },
                            "ops": [
                                {
                                    "subgraph": {
                                        "name": "Terrain Resolve"
                                    }
                                },
                                {
                                    "subgraph": {
                                        "name": "Vegetation Render"
                                    }
                                },
                                {
                                    "batch": {
                                        "name": "FlatGeometryLit"
                                    }
                                },
                                {
                                    "batch": {
                                        "name": "LightMeshes"
                                    }
                                },
                                {
                                    "subgraph": {
                                        "name": "DDGI Debug"
                                    }
                                }
                            ]
                        }
                    },
                    {
                        "render": {
                            "name": "Sky Pass",
                            "targets": [
                                {
                                    "name": "LightBufferMS",
                                    "flags": "Load|Store",
                                    "resolve": "LightBuffer"
                                }
                            ],
                            "depth": {
                                "name": "ZBufferMS",
                                "flags": "Load|Store"
                            },
                            "ops": [
                                {
                                    "batch": {
                                        "name": "Background"
                                    }
                                }
                            ]
                        }
                    },
                    {
                        "render": {
                            "name": "Alpha Pass",
                            "targets": [
                                {
                                    "name": "AlphaLightBufferMS",
                                    "clear": [
                                        0,
                                        0,
                                        0,
                                        0
                                    ],
                                    "flags": "Store",
                                    "resolve": "AlphaLightBuffer"
                                        
                                }
                            ],
                            "depth": {
                                "name": "ZBufferMS",
                                "flags": "Load|Store",
                                "resolve": "ZBuffer"
                            },
                            "resource_dependencies": [
                                {
                                    "name": "LightBuffer",
                                    "stage": "PixelShaderRead"
                                }
                            ],
                            "ops": [
                                {
                                    "batch": {
                                        "name": "FlatGeometryAlphaLit"
                                    }
                                },
                                {
                                    "batch": {
                                        "name": "ParticleLit"
                                    }
                                }
                            ]
                        }
                    },

                    {
                        "subgraph": {
                            "name": "Raytracing Test"
                        }
                    },
                    {
                        "subgraph": {
                            "name": "Vegetation Copy Indirect"
                        }
                    },

                    {
                        "subgraph": {
                            "name": "HBAO X"
                        }
                    },
                    {
                        "subgraph": {
                            "name": "HBAO Y"
                        }
                    },
                    {
                        "subgraph": {
                            "name": "HBAO Blur X"
                        }
                    },
                    {
                        "subgraph": {
                            "name": "HBAO Blur Y"
                        }
                    },

                    {
                        "subgraph": {
                            "name": "Fog Compute"
                        }
                    },

                    {
                        "subgraph": {
                            "name": "Fog Blur X"
                        }
                    },

                    {
                        "subgraph": {
                            "name": "Fog Blur Y"
                        }
                    },

                    {
                        "subgraph": {
                            "name": "Lights Combine"
                        }
                    },

                    {
                        "subgraph": {
                            "name": "Color Downsample"
                        }
                    },

                    {
                        "subgraph": {
                            "name": "Histogram Bin"
                        }
                    },
                    {
                        "subgraph": {
                            "name": "Histogram Copy"
                        }
                    },
                    {
                        "subgraph": {
                            "name": "Histogram Clear"
                        }
                    },

                    {
                        "subgraph": {
                            "name": "Bloom Intermediate"
                        }
                    },
                    {
                        "subgraph": {
                            "name": "Bloom Merge"
                        }
                    },

                    {
                        "render": {
                            "name": "Post Effects",
                            "targets": [
                                {
                                    "name": "ColorBuffer",
                                    "flags": "Load|Store"
                                }
                            ],
                            "depth": {
                                "name": "ZBuffer",
                                "flags": "Load"
                            },
                            "resource_dependencies": [
                                {
                                    "name": "BloomBuffer",
                                    "stage": "PixelShaderRead"
                                },
                                {
                                    "name": "LightBuffer",
                                    "stage": "PixelShaderRead"
                                },
                                {
                                    "name": "Depth",
                                    "stage": "PixelShaderRead"
                                }
                            ],
                            "ops": [
                                {
                                    "fullscreen_effect": {
                                        "name": "Finalize",
                                        "shader": "system_shaders/finalize",
                                        "mask": "Alt0",
                                        "namespace": "Finalize",
                                        "constantBlockName": "FinalizeUniforms",
                                        "variables": [
                                            {
                                                "semantic": "DepthTexture",
                                                "value": "Depth",
                                                "type": "textureHandle"
                                            },
                                            {
                                                "semantic": "ColorTexture",
                                                "value": "LightBuffer",
                                                "type": "textureHandle"
                                            },
                                            {
                                                "semantic": "BloomTexture",
                                                "value": "BloomBuffer",
                                                "type": "textureHandle"
                                            }
                                        ],
                                        "size_from_texture": "ColorBuffer"
                                    }
                                }
                            ]
                        }
                    },
                    {
                        "render": {
                            "name": "Direct",
                            "targets": [
                                {
                                    "name": "ColorBuffer",
                                    "flags": "Load|Store"
                                }
                            ],
                            "depth": {
                                "name": "ZBuffer",
                                "flags": "Load"
                            },

                            "resource_dependencies": [
                                {
                                    "name": "Depth",
                                    "stage": "VertexShaderRead"
                                }
                            ],
                            "ops": [
                                {
                                    "batch": {
                                        "name": "DirectToColor"
                                    }
                                },
                                {
                                    "batch": {
                                        "name": "ParticleUnlit"
                                    }
                                },

                                {
                                    "subgraph": {
                                        "name": "TerrainEditorBrush"
                                    }
                                },
                                {
                                    "subgraph": {
                                        "name": "Im3D"
                                    }
                                }
                            ]
                        }
                    },
                    {
                        "render": {
                            "name": "UI",
                            "targets": [
                                {
                                    "name": "ColorBuffer",
                                    "flags": "Load|Store"
                                }
                            ],
                            "ops": [
                                {
                                    "subgraph": {
                                        "name": "ImGUI"
                                    }
                                }
                            ]
                        }
                    },
                    {
                        "copy": {
                            "name": "ColorBuffer Copy",
                            "from": {
                                "tex": "ColorBuffer",
                                "bits": "ColorBits"
                            },
                            "to": {
                                "tex": "SceneBuffer",
                                "bits": "ColorBits"
                            }
                        }
                    },
                    {
                        "render": {
                            "name": "GUI",
                            "resource_dependencies": [
                                {
                                    "name": "Depth",
                                    "stage": "PixelShaderRead"
                                }
                            ],
                            "targets": [
                                {
                                    "name": "ColorBuffer",
                                    "flags": "Load|Store"
                                }
                            ],
                            "depth": {
                                "name": "ZBuffer",
                                "flags": "Load|Discard"
                            },
                            "ops": [
                                {
                                    "subgraph": {
                                        "name": "Debug Shapes"
                                    }
                                },
                                {
                                    "subgraph": {
                                        "name": "StaticUI To Backbuffer"
                                    }
                                }
                            ]
                        }
                    },
                    {
                        "transition": {
                            "name": "ColorBuffer",
                            "stage": "ComputeShaderRead"
                        }
                    }
                ]
            }
        ]
    }
}
