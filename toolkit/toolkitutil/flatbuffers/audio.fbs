include "foundation/math.fbs";

namespace ToolkitUtil;

enum AudioContainer : byte
{
	Unknown = 0,
	MP3 = 1,
	WAV = 2,
	OGG = 3,
	FLAC = 4
}

table AudioResource
{
	container : AudioContainer;
	data : [ubyte];
}


root_type AudioResource;
file_identifier "AUDI";
file_extension "naaud";