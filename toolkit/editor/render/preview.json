                        }
                    },
                    {
                        "subgraph": {
                            "name": "Decal Cull"
                        }
                    },
                    {
                        "subgraph": {
                            "name": "Fog Copy"
                        }
                    },
                    {
                        "subgraph": {
                            "name": "Fog Cull"
                        }
                    },
                    {
                        "subgraph": {
